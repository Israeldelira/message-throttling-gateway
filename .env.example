
# Node environment (development, production, test)
NODE_ENV=development

# Server port
PORT=3000

# Message throttling limit (maximum messages allowed)
MESSAGE_LIMIT=100

# Dispatcher automatic process interval in milliseconds
DISPATCH_INTERVAL_MS=1000

# Provider request timeout in milliseconds
PROVIDER_REQUEST_TIMEOUT_MS=5000

# Default message count used by POST /messages/batch-process
BATCH_PROCESS_DEFAULT_TOTAL_MESSAGES=100000

# Number of concurrent HTTP requests used by POST /messages/batch-process
BATCH_PROCESS_REQUEST_CONCURRENCY=200

# Mock provider limit per second
MOCK_PROVIDER_MAX_MESSAGES_PER_SECOND=100

#Database configuration
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_NAME=message_db
DB_SYNCHRONIZE=true
DB_LOGGING=false
